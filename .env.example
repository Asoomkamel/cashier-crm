# Public application URLs
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_ORG_ID=YOUR_ORGANIZATION_UUID
NEXT_PUBLIC_BRANCH_ID=YOUR_BRANCH_UUID

# Server-only security values
SERVER_ACTION_SECRET=CHANGE_TO_A_LONG_RANDOM_SECRET
ADMIN_ACTION_CODE=CHANGE_TO_A_PRIVATE_ADMIN_CODE

# Google Gemini (optional)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Authentica OTP (optional)
AUTHENTICA_API_KEY_BASE64=YOUR_AUTHENTICA_API_KEY_BASE64
AUTHENTICA_EMAIL_METHOD=email
AUTHENTICA_EMAIL_SEND_OTP_URL=https://api.authentica.sa/api/v2/send-otp
AUTHENTICA_EMAIL_VERIFY_OTP_URL=https://api.authentica.sa/api/v2/verify-otp

# Feature flags: keep disabled until the related server/RLS setup is complete
NEXT_PUBLIC_USE_SERVER_CHECKOUT=false
NEXT_PUBLIC_USE_SUPABASE_AUTH=false
NEXT_PUBLIC_USE_IDB_CACHE=false
